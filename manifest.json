{
    "manifest_version": 3,
    "name": "AlgoSync",
    "description": "Automatically sync accepted LeetCode solutions to GitHub.",
    "version": "1.0",
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://leetcode.com/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "https://leetcode.com/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "inject.js"
            ],
            "matches": [
                "https://leetcode.com/*"
            ]
        }
    ],
    "background": {
        "service_worker": "background.js"
    }
}